# ── Django ──
SECRET_KEY=change-me
DEBUG=False
# sqlite для локалки: sqlite:///db.sqlite3 ; прод: postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT (опционально) ──
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14

# ── Суперюзер для createsuperuser --noinput ──
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@alrig.tj
DJANGO_SUPERUSER_PASSWORD=change-me

# ── S3 медиа (опционально — если пусто, файлы хранятся локально в media/) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=

# ── Telegram-уведомления о заявках (опционально) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
